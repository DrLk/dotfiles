[core]
    pager = delta
	autocrlf = false
	sshCommand = ssh -i ~/.ssh/id_rsa

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # use n and N to move between diff sections
    hyperlinks = true

    # delta detects terminal colors automatically; set one of these to disable auto-detection
    # dark = true
    # light = true

[help]
    autocorrect = 1

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default
    algorithm = histogram

[user]
	email = yermakovich.andrei2005@gmail.com
	name = Ermakovich Andrew
	signingkey = ~/.ssh/id_rsa.pub

[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers

[commit]
	gpgsign = true
[tag]
	gpgsign = true
	sort = -version:refname

[branch]
	sort = -committerdate

[push]
	autoSetupRemote = true

[rebase]
	autosquash = true
	autostash = true
	updateRefs = true

[rerere]
	enabled = true

[init]
	defaultBranch = main

[includeIf "hasconfig:remote.*.url:git@github.com:bt-sync/**"]
	path = ~/.config/git/config.work
[includeIf "hasconfig:remote.*.url:https://github.com/bt-sync/**"]
	path = ~/.config/git/config.work
